# ===============================
# Zsh Options
# ~/.config/zsh/01-options.zsh
# ===============================

setopt \
  autocd \
  interactive_comments \
  multios \
  extended_glob \
  auto_pushd \
  pushd_ignore_dups \
  pushdminus \
  pushd_silent \
  no_beep \
  auto_menu \
  prompt_subst \
  correct
